flowchart TB
    subgraph NAV["NAVIGATION"]
        direction LR
        HOME["Upload Page"]
        OVER["Overview"]
        SEC["Sector Detail"]
        HOME -->|after upload| OVER
        OVER -->|click on sector| SEC
        SEC -->|back| OVER
    end

    subgraph OVERVIEW["OVERVIEW (Main Dashboard)"]
        direction TB
        FILTER_P["Filter: Period\n(month/year)"]
        AGG_SET["Aggregate by Sector\n11 sectors"]
        AGG_VIO["Count Violations\nby type"]
        SEVERITY["Apply Severity\nRed/Yellow/Green"]
        VARIATION["Calculate Variation\nvs previous month\nvs yearly average\nvs same month last year"]
        FILTER_P --> AGG_SET --> AGG_VIO --> SEVERITY --> VARIATION
    end

    subgraph DETAIL["SECTOR DETAIL"]
        direction TB
        FILTER_S["Filter: Sector + Period"]
        BREAK["Breakdown by Type\n5 violations"]
        COUNT["Counts:\nEmployees,\nOccurrences,\nHours"]
        SEV_D["Severity\nby type"]
        FILTER_S --> BREAK --> COUNT --> SEV_D
    end

    subgraph VIS["VISUALIZATION"]
        direction TB
        BAR["Horizontal\nBar Charts"]
        TABLE["Tables with\nSeverity Colors"]
        TOOLTIP["Interactive Tooltips\n(on hover)"]
    end

    OVERVIEW --> BAR
    OVERVIEW --> TABLE
    DETAIL --> BAR
    DETAIL --> TABLE

    style NAV fill:#e0f7fa,stroke:#00695c
    style OVERVIEW fill:#e3f2fd,stroke:#1565c0
    style DETAIL fill:#e8f5e9,stroke:#2e7d32
    style VIS fill:#f3e5f5,stroke:#6a1b9a
