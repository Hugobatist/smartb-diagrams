flowchart TB
    CLT["CLT - Brazilian Labor Laws\nMonitored Work Schedule Rules"]

    subgraph V1["OVER 6 CONSECUTIVE DAYS"]
        direction TB
        R1["Rule: Max 6 days\nwithout rest"]
        D1["Data: Employee,\nDate, Next Rest Day"]
        S1["Severity:\nRed >= 3 occurrences\nYellow >= 7 occurrences"]
    end

    subgraph V2["REST UNDER 35 HOURS"]
        direction TB
        R2["Rule: Weekly rest\nminimum 35 hours"]
        D2["Data: Employee,\nRest Date, Rest Hours"]
        S2["Severity:\nRed >= 5 occurrences\nYellow >= 12 occurrences"]
    end

    subgraph V3["INTER-SHIFT UNDER 11 HOURS"]
        direction TB
        R3["Rule: Gap between\nshifts minimum 11h"]
        D3["Data: Employee,\nDate, Inter-shift Gap"]
        S3["Severity:\nRed >= 5 occurrences\nYellow >= 12 occurrences"]
    end

    subgraph V4["INTRA-SHIFT UNDER 00:30"]
        direction TB
        R4["Rule: Break within\nshift minimum 30min\n(when shift > 6h)"]
        D4["Data: Employee,\nDate, Break Duration"]
        S4["Severity:\nRed >= 5 occurrences\nYellow >= 12 occurrences"]
    end

    subgraph V5["EXCESS WORK HOURS"]
        direction TB
        R5["Rule: Hours worked\ncannot exceed\ncontracted schedule"]
        D5["Data: Employee,\nDate, Schedule, Worked"]
        S5["Severity:\nRed >= 10 occurrences\nYellow >= 25 occurrences"]
    end

    CLT --> V1
    CLT --> V2
    CLT --> V3
    CLT --> V4
    CLT --> V5

    style V1 fill:#ffebee,stroke:#c62828
    style V2 fill:#fff3e0,stroke:#e65100
    style V3 fill:#e3f2fd,stroke:#1565c0
    style V4 fill:#e8f5e9,stroke:#2e7d32
    style V5 fill:#f3e5f5,stroke:#6a1b9a
