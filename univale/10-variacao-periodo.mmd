flowchart TB
    CURRENT["Current Period\n(e.g.: Dec/2025)"]

    subgraph COMPARISONS["3 COMPARISON AXES"]
        direction TB

        subgraph VS_PREV["vs Previous Month"]
            direction TB
            PREV["Period: Nov/2025"]
            CALC_P["variation % =\n(current - previous) / previous x 100"]
            PREV --> CALC_P
        end

        subgraph VS_AVG["vs Yearly Average"]
            direction TB
            AVG["Average: Jan-Dec 2025\n(all available months)"]
            CALC_A["variation % =\n(current - average) / average x 100"]
            AVG --> CALC_A
        end

        subgraph VS_SAME["vs Same Month Last Year"]
            direction TB
            SAME["Period: Dec/2024"]
            CALC_S["variation % =\n(current - previous) / previous x 100"]
            NULL_S["If no data available:\nshow dash (no comparison)"]
            SAME --> CALC_S
            SAME -->|no data| NULL_S
        end
    end

    subgraph DISPLAY["DISPLAY"]
        direction TB
        UP_ARROW["Arrow Up\n(increase = worse)"]
        DOWN_ARROW["Arrow Down\n(decrease = better)"]
        NEUTRAL["Dash\n(no comparative data)"]
    end

    CURRENT --> COMPARISONS
    COMPARISONS --> DISPLAY

    style VS_PREV fill:#e3f2fd,stroke:#1565c0
    style VS_AVG fill:#e8f5e9,stroke:#2e7d32
    style VS_SAME fill:#fff3e0,stroke:#e65100
    style DISPLAY fill:#f3e5f5,stroke:#6a1b9a
