flowchart TB
    subgraph MONTHLY["MONTHLY CYCLE"]
        direction TB
        EXP["Operator exports CSVs\nfrom timekeeping system\n(~50 files)"]
        UP["Assistant uploads\nto Univale BI\n(selects sector + period)"]
        AUTO["System auto-detects\neach CSV type"]
        PROC["System processes\nand stores"]
        EXP --> UP --> AUTO --> PROC
    end

    subgraph ANALYSIS["MANAGEMENT ANALYSIS"]
        direction TB
        OVER["Access Overview\nCompare all sectors"]
        IDENT["Identify sectors\nwith red alerts"]
        DRILL["Drill into detail\nof critical sector"]
        RANK["Check employee\nranking"]
        OVER --> IDENT --> DRILL --> RANK
    end

    subgraph ACTION["CORRECTIVE ACTIONS"]
        direction TB
        GESTOR["Sector manager\nreceives alert"]
        PLAN["Plans corrective\nschedule"]
        MONITOR["Monitors progress\nnext month"]
        GESTOR --> PLAN --> MONITOR
    end

    subgraph TREND["TRACKING"]
        direction TB
        HIST["Historical view\nYearly trends"]
        COMP["Comparison\nMonth to month"]
        EXCEL["Export Excel\nfor meetings"]
    end

    PROC --> OVER
    RANK --> GESTOR
    MONITOR --> HIST
    HIST --> COMP --> EXCEL

    style MONTHLY fill:#e3f2fd,stroke:#1565c0
    style ANALYSIS fill:#e8f5e9,stroke:#2e7d32
    style ACTION fill:#fff3e0,stroke:#e65100
    style TREND fill:#f3e5f5,stroke:#6a1b9a
