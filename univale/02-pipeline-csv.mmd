flowchart TB
    START["CSV Files Received\n(Latin-1 or UTF-8, delimiter ;)"]

    subgraph STAGE1["1. ENCODING DETECTION"]
        direction TB
        CHARDET["chardet\nIdentifies encoding"]
        ICONV["iconv-lite\nConverts to UTF-8"]
        CHARDET --> ICONV
    end

    subgraph STAGE2["2. CSV PARSING"]
        direction TB
        PAPA["PapaParse\nDelimiter: ;\nNo header"]
        LINHAS["Raw Rows\nText matrix"]
        PAPA --> LINHAS
    end

    subgraph STAGE3["3. TYPE DETECTION"]
        direction TB
        HEADER["Header Reading\nFirst Row"]
        REGEX["Pattern Matching\n5 signatures"]
        TIPO["Type Identified\n(1 of 5 violations)"]
        HEADER --> REGEX --> TIPO
    end

    subgraph STAGE4["4. NORMALIZATION"]
        direction TB
        N1["Over 6 Days\nConsecutive days"]
        N2["Rest under 35h\nInsufficient rest"]
        N3["Inter-shift under 11h\nBetween shifts"]
        N4["Intra-shift under 30min\nShort break"]
        N5["Excess Work Hours\nOvertime hours"]
    end

    subgraph STAGE5["5. PERSISTENCE"]
        direction TB
        DEDUP["Deduplication\ncode|date|type|sector"]
        UPSERT["Insert or Update\n(avoids duplicates)"]
        JSON["File store.json\nEvent list"]
        DEDUP --> UPSERT --> JSON
    end

    START --> STAGE1
    STAGE1 --> STAGE2
    STAGE2 --> STAGE3
    TIPO -->|Consecutive days| N1
    TIPO -->|Insufficient rest| N2
    TIPO -->|Inter-shift| N3
    TIPO -->|Intra-shift| N4
    TIPO -->|Excess hours| N5
    STAGE4 --> STAGE5

    style STAGE1 fill:#e3f2fd,stroke:#1565c0
    style STAGE2 fill:#e8f5e9,stroke:#2e7d32
    style STAGE3 fill:#fff3e0,stroke:#e65100
    style STAGE4 fill:#f3e5f5,stroke:#6a1b9a
    style STAGE5 fill:#fce4ec,stroke:#c62828
