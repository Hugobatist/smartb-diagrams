flowchart TB
    subgraph EVENT["Canonical Event (Main Model)"]
        direction TB
        ID["Identifier\n(unique code)"]
        EMP_CODE["Employee Code\n(e.g.: 322156)"]
        EMP_NAME["Employee Name\n(e.g.: VALDIR PEREIRA LIRO)"]
        DATE["Date\n(e.g.: 22/12/2025)"]
        SECTOR["Sector\n(e.g.: Linhas)"]
        PERIOD["Period\n(e.g.: Dec/2025)"]
        VTYPE["Violation Type\n(1 of 5 types)"]
        DETAILS["Details\n(type-specific fields)"]
        UPLOADED["Upload Date\n(registration timestamp)"]
    end

    subgraph DEDUP_KEY["Deduplication Key"]
        KEY["Employee Code |\nDate | Violation Type | Sector"]
    end

    subgraph SECTORS["11 Sectors"]
        direction TB
        S1["Linhas"]
        S2["Bemisa"]
        S3["Usiminas Charter"]
        S4["Cenibra/Tourism"]
        S5["Vale - Mining - Mariana"]
        S6["Vale - Mining - Sta. Barbara"]
        S7["Bahia Operations"]
        S8["Bahia Charter"]
        S9["Aperam"]
        S10["Cipalam"]
        S11["Usiminas Mining"]
    end

    subgraph TYPES["Violation Types"]
        direction TB
        T1["Consecutive Days\n(over 6)"]
        T2["Insufficient Rest\n(under 35h)"]
        T3["Inter-shift\n(under 11h)"]
        T4["Intra-shift\n(under 30min)"]
        T5["Excess Hours\n(overtime)"]
    end

    subgraph STORAGE["Persistence"]
        direction TB
        MEM["In-Memory Store\n(loaded data)"]
        DISK["File on Disk\ndata/store.json"]
        MEM -->|save| DISK
        DISK -->|load| MEM
    end

    EVENT --> DEDUP_KEY
    SECTOR --> SECTORS
    VTYPE --> TYPES
    EVENT --> STORAGE

    style EVENT fill:#e3f2fd,stroke:#1565c0
    style DEDUP_KEY fill:#fff3e0,stroke:#e65100
    style SECTORS fill:#e8f5e9,stroke:#2e7d32
    style TYPES fill:#f3e5f5,stroke:#6a1b9a
    style STORAGE fill:#fce4ec,stroke:#c62828
