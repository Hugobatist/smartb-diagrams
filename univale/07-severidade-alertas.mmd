flowchart TB
    EVENTO["Occurrence Count\nby Sector/Type/Period"]

    subgraph RULES["SEVERITY RULES BY TYPE"]
        direction TB

        subgraph CONSEC["Consecutive Days"]
            C_R["RED: >= 3"]
            C_Y["YELLOW: >= 7"]
            C_G["GREEN: < 3"]
        end

        subgraph REST["Rest < 35h"]
            F_R["RED: >= 5"]
            F_Y["YELLOW: >= 12"]
            F_G["GREEN: < 5"]
        end

        subgraph INTER["Inter-shift < 11h"]
            I_R["RED: >= 5"]
            I_Y["YELLOW: >= 12"]
            I_G["GREEN: < 5"]
        end

        subgraph INTRA["Intra-shift < 30min"]
            J_R["RED: >= 5"]
            J_Y["YELLOW: >= 12"]
            J_G["GREEN: < 5"]
        end

        subgraph EXCESS["Excess Hours"]
            E_R["RED: >= 10"]
            E_Y["YELLOW: >= 25"]
            E_G["GREEN: < 10"]
        end
    end

    subgraph INDICATORS["VISUAL INDICATORS"]
        direction TB
        RED["Red\nImmediate action"]
        YELLOW["Yellow\nAttention needed"]
        GREEN["Green\nWithin acceptable"]
    end

    EVENTO --> RULES
    RULES --> INDICATORS

    style CONSEC fill:#ffebee,stroke:#c62828
    style REST fill:#fff3e0,stroke:#e65100
    style INTER fill:#e3f2fd,stroke:#1565c0
    style INTRA fill:#e8f5e9,stroke:#2e7d32
    style EXCESS fill:#f3e5f5,stroke:#6a1b9a
    style INDICATORS fill:#fffde7,stroke:#f57f17
    style RED fill:#ef5350,stroke:#b71c1c,color:#fff
    style YELLOW fill:#ffc107,stroke:#ff8f00
    style GREEN fill:#66bb6a,stroke:#2e7d32,color:#fff
