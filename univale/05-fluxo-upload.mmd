flowchart TB
    USER["Assistant\naccesses Upload page"]

    subgraph FORM["UPLOAD FORM"]
        direction TB
        FILES["Select CSVs\n(multiple files)"]
        SETOR["Choose Sector\n(list with 11 options)"]
        PERIODO["Choose Period\n(Month/Year)"]
        BTN["Click Submit"]
        FILES --> SETOR --> PERIODO --> BTN
    end

    subgraph BACKEND["SERVER PROCESSING"]
        direction TB
        RECEBE["Server receives\nthe files"]
        LOOP["For each file:"]

        subgraph VALIDATION["VALIDATION"]
            direction TB
            EXT["Check .csv extension"]
            ENC["Detect encoding"]
            PARSE["Parse CSV"]
            DETECT["Detect type\nby header"]
        end

        subgraph TRANSFORM["TRANSFORMATION"]
            direction TB
            NORM["Normalize to\nCanonical Event"]
            VALID["Validate data\nstructure"]
        end

        subgraph PERSIST["PERSISTENCE"]
            direction TB
            DEDUP["Deduplication\nInsert or Update"]
            SAVE["Save to\nData Store"]
        end

        RECEBE --> LOOP
        LOOP --> VALIDATION
        VALIDATION --> TRANSFORM
        TRANSFORM --> PERSIST
    end

    subgraph RESPONSE["RESPONSE"]
        direction TB
        OK["Success\nImported count\nby type"]
        ERR["Error\nUser-friendly message\n(file skipped)"]
    end

    USER --> FORM
    BTN --> BACKEND
    PERSIST --> OK
    VALIDATION -->|failure| ERR

    style FORM fill:#e3f2fd,stroke:#1565c0
    style BACKEND fill:#e8f5e9,stroke:#2e7d32
    style VALIDATION fill:#fff3e0,stroke:#e65100
    style TRANSFORM fill:#f3e5f5,stroke:#6a1b9a
    style PERSIST fill:#fce4ec,stroke:#c62828
    style RESPONSE fill:#e0f7fa,stroke:#00695c
