flowchart LR
    subgraph BROWSER["BROWSER (User Screen)"]
        direction TB
        HTML["Plain HTML5\n3 pages"]
        CSS["Custom CSS\nResponsive"]
        JS["Modular JavaScript\nNo framework"]
        CHARTJS["Chart Library\n(Chart.js local)"]
        HTML --> JS
        CSS --> HTML
        JS --> CHARTJS
    end

    subgraph SERVER["SERVER (Express.js)"]
        direction TB
        STATIC["Serves Static Pages\npublic/ folder"]
        API["Data API\n/api/*"]

        subgraph ROUTES["ROUTES"]
            R_UP["File Upload\nPOST /api/upload"]
            R_OV["Overview\nGET /api/dashboard/overview"]
            R_SD["Sector Detail\nGET /api/dashboard/sector-detail"]
            R_SEC["Sector List\nGET /api/sectors"]
        end

        subgraph SERVICES["SERVICES"]
            AGG["Data Aggregation\n(calculated on demand)"]
        end

        subgraph PARSERS["PARSERS"]
            P_ENC["Encoding\n(chardet + iconv)"]
            P_CSV["CSV Reader\n(PapaParse)"]
            P_DET["Type Detector\n(header matching)"]
            P_DAT["Dates\n(DD/MM/YYYY format)"]
            P_DUR["Durations\n(HH:MM format)"]
            P_EMP["Employees\n(code + name)"]
        end

        subgraph NORMS["NORMALIZERS"]
            N1["Over 6 Days"]
            N2["Rest under 35h"]
            N3["Inter-shift under 11h"]
            N4["Intra-shift under 30min"]
            N5["Excess Hours"]
        end
    end

    subgraph DATA["DATA"]
        direction TB
        STORE["In-Memory Store\n(loaded data)"]
        FILE["File on Disk\ndata/store.json"]
        STORE <--> FILE
    end

    BROWSER <-->|HTTP| SERVER
    ROUTES --> SERVICES
    R_UP --> PARSERS
    PARSERS --> NORMS
    NORMS --> STORE
    AGG --> STORE

    style BROWSER fill:#e3f2fd,stroke:#1565c0
    style SERVER fill:#e8f5e9,stroke:#2e7d32
    style ROUTES fill:#fff3e0,stroke:#e65100
    style SERVICES fill:#f3e5f5,stroke:#6a1b9a
    style PARSERS fill:#e0f7fa,stroke:#00695c
    style NORMS fill:#fce4ec,stroke:#c62828
    style DATA fill:#fffde7,stroke:#f57f17
