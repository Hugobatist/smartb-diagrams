flowchart LR
    subgraph SOURCE["DATA SOURCE"]
        direction TB
        PONTO["Timekeeping System\nWork Schedule Control"]
        CSV["CSV Export\n~50 files/month\n(5 types x ~10 sectors)"]
        PONTO --> CSV
    end

    subgraph INGEST["UPLOAD & INGESTION"]
        direction TB
        MULTI["Batch Upload\nMultiple CSVs"]
        DETECT["Auto-Detection\nReport Type"]
        SETOR["Sector Selection\n11 sectors"]
        PERIODO["Period Selection\nMonth/Year"]
        MULTI --> DETECT
        DETECT --> SETOR
        SETOR --> PERIODO
    end

    subgraph PIPELINE["DATA PROCESSING"]
        direction TB
        ENC["Encoding Detection\nLatin-1 / UTF-8"]
        PARSE["CSV Parsing\nDelimiter ;"]
        NORM["Normalization\n5 violation types"]
        DEDUP["Deduplication\nComposite key"]
        STORE["Persistence\nJSON file on disk"]
        ENC --> PARSE --> NORM --> DEDUP --> STORE
    end

    subgraph DASH["DASHBOARDS"]
        direction TB
        OVERVIEW["Overview\nAll Sectors"]
        DETAIL["Sector Detail\nMonthly Breakdown"]
        RANKING["Ranking\nEmployees"]
        TREND["Trends\nYearly View"]
        OVERVIEW --> DETAIL
        DETAIL --> RANKING
    end

    subgraph OUTPUT["OUTPUTS"]
        direction TB
        CHART["Interactive Charts"]
        SEVER["Severity Alerts\nRed / Yellow / Green"]
        EXPORT["Excel Export\nFormatted .xlsx"]
    end

    CSV --> MULTI
    PERIODO --> ENC
    STORE --> OVERVIEW
    OVERVIEW --> CHART
    OVERVIEW --> SEVER
    DETAIL --> EXPORT

    MULTI -->|"cade"| ENC
    style SOURCE fill:#e3f2fd,stroke:#1565c0
    style INGEST fill:#fff3e0,stroke:#e65100
    style PIPELINE fill:#e8f5e9,stroke:#2e7d32
    style DASH fill:#f3e5f5,stroke:#6a1b9a
    style OUTPUT fill:#fce4ec,stroke:#c62828