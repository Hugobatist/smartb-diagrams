{
  "name": "smartcode-vscode",
  "displayName": "SmartCode",
  "description": "Live AI reasoning diagrams in VS Code",
  "version": "0.1.0",
  "publisher": "smartcode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hugobatist/smartcode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": ["onWebviewPanel:smartcode.diagramPanel"],
  "contributes": {
    "configuration": {
      "title": "SmartCode",
      "properties": {
        "smartcode.serverUrl": {
          "type": "string",
          "default": "ws://localhost:3333/ws",
          "description": "WebSocket URL of the SmartCode server"
        },
        "smartcode.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to SmartCode server on startup"
        }
      }
    },
    "commands": [
      {
        "command": "smartcode.reconnect",
        "title": "SmartCode: Reconnect to Server"
      },
      {
        "command": "smartcode.openBrowser",
        "title": "SmartCode: Open in Browser"
      },
      {
        "command": "smartcode.showDiagram",
        "title": "SmartCode: Show Diagram Panel",
        "icon": "$(preview)"
      }
    ],
    "keybindings": [
      {
        "command": "smartcode.showDiagram",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.24.0",
    "@vscode/vsce": "^3.2.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
